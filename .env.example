# ══════════════════════════════════════════════════════════════════════════════
# BITGET SIGNAL BOT - ENVIRONMENT CONFIGURATION TEMPLATE
# ══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control — it contains secrets!
# 
# Run setup wizard: python setup.py (recommended for first-time setup)
# 

# ── TELEGRAM CONFIGURATION ─────────────────────────────────────────────────────
# Required for alert notifications. Leave empty to run without alerts.
# 
# Get bot token from @BotFather on Telegram
# To get chat ID: message your bot, then visit:
#   https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/getUpdates
# Look for the "id" field in the response.
#
TELEGRAM_BOT_TOKEN=8694694293:AAGn4BkIB-iXxT18xBzdw0Qd3eD6FgvjhY4
TELEGRAM_CHAT_ID=5825181230


# ── BITGET API AUTHENTICATION (OPTIONAL) ───────────────────────────────────────
# Leave ALL three empty to run in signals-only mode (no orders placed).
# 
# To enable automatic order placement:
# 1. Log in to Bitget: https://www.bitget.com/
# 2. Go to Account → API Management
# 3. Create a new API key with these permissions:
#    - Read: Account, Position, Order
#    - Trade: Create/Cancel Orders, Modify Leverage/Margin
# 4. Copy API Key, Secret, and Passphrase below
#
# ⚠️  SECURITY WARNING:
#   - Never share these credentials
#   - Use IP whitelist on Bitget account
#   - Rotate keys periodically
#   - This bot does NOT read incoming messages (signals-only)
#
BITGET_API_KEY=bg_6e8be11793012645a762b6d961f48f9a
BITGET_API_SECRET=94b2011ea940da5d1970af89cc0d2064a6fe6208b0a18990da8d09eb8b6b14d9
BITGET_PASSPHRASE=Pintu2580


# ── TRADING PAIRS (COMMA-SEPARATED) ────────────────────────────────────────────
# Symbols to scan for signals. Use USDT pairs for USDT-FUTURES.
# Example: BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
#
WHITELIST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,LTCUSDT

# Minimum 24h trading volume to consider a pair. Filters out low-liquidity assets.
MIN_24H_QUOTE_VOLUME_USDT=20000000


# ── TIMEFRAMES ─────────────────────────────────────────────────────────────────
# Valid: 1m, 3m, 5m, 15m, 30m, 1H, 4H, 6H, 12H, 1D, 3D, 1W, 1M
# 
# TREND_TIMEFRAME:  Higher timeframe for dominant trend direction (e.g., 4H)
# SIGNAL_TIMEFRAME: Lower timeframe for entry signals (e.g., 1H)
#
# Typical setup: 4H trend + 1H signals (good for swing trading)
# Aggressive:    1H trend + 15m signals (day trading style)
# Conservative:  Daily trend + 4H signals
#
TREND_TIMEFRAME=4H
SIGNAL_TIMEFRAME=1H

# Number of candles to fetch for indicator warmup (200-1000).
# Larger = more reliable indicators but slower startup. Default: 200
CANDLE_LIMIT=200


# ── TECHNICAL INDICATORS ──────────────────────────────────────────────────────
# EMA (Exponential Moving Average)
EMA_FAST=20
EMA_SLOW=50

# RSI (Relative Strength Index) - Range: 0-100
RSI_PERIOD=14
RSI_OVERBOUGHT=70        # Signals are filtered out above this
RSI_OVERSOLD=30          # Signals are filtered out below this

# ATR (Average True Range) - Used for stop loss & take profit sizing
ATR_PERIOD=14

# Breakout detection
BREAKOUT_LOOKBACK=20     # Look back N candles for recent high/low
VOLUME_SPIKE_MULTIPLIER=1.5  # Volume must exceed average by this factor


# ── FUNDING RATE FILTER (PERPETUAL FUTURES ONLY) ────────────────────────────────
# Skips signals where funding rate exceeds this threshold (absolute value).
# 
# Funding rates indicate market sentiment:
#   Positive = longs are paying shorts (expect reversal)
#   Negative = shorts are paying longs (expect bounce)
#   Extreme rates = overcrowded positions = higher risk
# 
# Default 0.0008 = 0.08%. Increase to be more aggressive, decrease to be conservative.
#
MAX_ABS_FUNDING_RATE=0.0008


# ── RISK MANAGEMENT ────────────────────────────────────────────────────────────
# Stop loss & take profit are calculated as: entry ± (ATR × multiplier)
# These control reward:risk ratio.
# 
# ATR_STOP_MULTIPLIER=1.5   →  SL = entry ± (1.5 × ATR)
# ATR_TARGET_MULTIPLIER=2.5 →  TP = entry ± (2.5 × ATR)
# R:R ratio = 2.5/1.5 = 1.67 (want 2.5x positive expected value)
#
ATR_STOP_MULTIPLIER=1.5
ATR_TARGET_MULTIPLIER=2.5

# Maximum risk per trade as % of account balance.
# This is the amount you're willing to lose on a single trade.
# Conservative: 0.5%, Balanced: 1%, Aggressive: 2%
#
ACCOUNT_RISK_PERCENT=1.0

# Maximum leverage suggested in signals (1-125x).
# Only used if auto-orders are enabled.
#
MAX_LEVERAGE_SUGGESTED=5


# ── AUTOMATED ORDER PLACEMENT (requires BITGET_API_KEY) ──────────────────────
# Set ENABLE_AUTO_ORDERS=true to have the bot automatically place orders.
# 
# WARNING: Only enable if you fully understand the risks!
#          - Test on paper trading first
#          - Start with small position sizes
#          - Monitor the bot closely
#          - Futures leverage can cause rapid account liquidation
#
ENABLE_AUTO_ORDERS=false

# Order type when auto-orders are enabled
#   "limit"  = Place limit orders (safer, may not fill)
#   "market" = Place market orders (fills immediately but at market price)
#
AUTO_ORDER_TYPE=limit

# Leverage to use for auto-orders (1-20x)
AUTO_ORDER_LEVERAGE=3

# Margin mode for auto-orders
#   "isolated" = Risk only the position margin (safer)
#   "crossed"  = Risk entire account balance (more aggressive)
#
AUTO_ORDER_MARGIN_MODE=isolated

# Position size as % of account balance per trade.
# If your account is $10,000 and this is 2%, each position = $200 margin
#
POSITION_SIZE_PERCENT=2.0


# ── POLLING & COOLDOWNS ───────────────────────────────────────────────────────
# How often to scan the market for signals (in seconds).
# 
# Recommended values:
#   300s  (5m)   = Very aggressive, high API usage
#   600s  (10m)  = Aggressive
#   900s  (15m)  = Balanced (default, recommended)
#   1800s (30m)  = Conservative, low API usage
#
POLL_INTERVAL_SECONDS=900

# Minimum minutes between repeat signals for the same pair & direction.
# Prevents signal spam on the same pair.
# E.g., if BTCUSDT LONG fires, next BTCUSDT LONG won't fire for 240 minutes.
#
MIN_MINUTES_BETWEEN_REPEAT_SIGNAL=240

# If a scan encounters an error, back off before retrying (in seconds).
SCAN_ERROR_BACKOFF_SECONDS=30


# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite database for signal history and performance tracking.
#
DB_PATH=signal_bot.db

# Busy timeout (seconds) prevents database locks during concurrent access.
DB_BUSY_TIMEOUT_SECONDS=30


# ── LOGGING ───────────────────────────────────────────────────────────────────
# Log file location
LOG_FILE=signal_bot.log

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file rotation settings (to prevent unbounded growth)
LOG_MAX_BYTES=10485760      # 10 MB
LOG_BACKUP_COUNT=5          # Keep 5 old logs


# ── BITGET API SETTINGS ────────────────────────────────────────────────────────
# Base URL for Bitget API (use default unless Bitget changes it)
BITGET_BASE_URL=https://api.bitget.com

# HTTP request timeout (seconds)
REQUEST_TIMEOUT_SECONDS=10

# Max retries on transient errors (network, 5xx, rate-limit)
HTTP_MAX_RETRIES=3

# Backoff multiplier for retries (exponential: 1.5s, 3s, 4.5s, etc.)
HTTP_RETRY_BACKOFF_SECONDS=1.5

# Minimum gap between API requests to avoid rate-limiting
MIN_SECONDS_BETWEEN_REQUESTS=0.2

# ══════════════════════════════════════════════════════════════════════════════
# QUICK START
# ══════════════════════════════════════════════════════════════════════════════
# 
# 1. Minimum setup (signals only, no auto-orders):
#    - Set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID
#    - Set WHITELIST_SYMBOLS
#    - Run: python main.py
# 
# 2. With auto-orders (requires Bitget account):
#    - Complete setup above, PLUS:
#    - Set BITGET_API_KEY, BITGET_API_SECRET, BITGET_PASSPHRASE
#    - Set ENABLE_AUTO_ORDERS=true
#    - Set AUTO_ORDER_LEVERAGE, AUTO_ORDER_MARGIN_MODE, POSITION_SIZE_PERCENT
#    - TEST ON PAPER TRADING FIRST!
# 
# 3. Using setup wizard (recommended):
#    python setup.py
# 
# 4. Verify configuration:
#    python main.py  (will validate config before starting)
# 
# ══════════════════════════════════════════════════════════════════════════════
